# Copy this file to .env and fill in your values
# Get your API key from https://dune.com/settings/api

# Your Dune API key
VITE_DUNE_API_KEY=your_api_key_here

# The numeric ID of your saved Dune query
# Found in the URL: https://dune.com/queries/YOUR_QUERY_ID
# Default should be 6743629 (original single-token query — kept for rollback)
VITE_DUNE_QUERY_ID=6743629

# Phase 2: multi-address volume-by-pool query.
# Saved at https://dune.com/queries/7582218
VITE_DUNE_VOLUME_QUERY_ID=7582218

# Phase 4: source-attribution query (aggregator / CoW solver / direct).
# Saved at https://dune.com/queries/7582229
VITE_DUNE_SOURCE_QUERY_ID=7582229
