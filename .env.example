# Copy this file to .env and fill in your values
# Get your API key from https://dune.com/settings/api
#
# NOTE: The Dune API key is no longer read from .env. Each user pastes
# their own key into the in-app "Dune API key" panel; the key is stored
# in localStorage. This .env file only carries the (non-secret) saved
# query IDs that the deployed app needs at build time.

# The numeric ID of your saved Dune query
# Found in the URL: https://dune.com/queries/YOUR_QUERY_ID
# Default should be 6743629 (original single-token query — kept for rollback)
VITE_DUNE_QUERY_ID=6743629

# Phase 2: multi-address volume-by-pool query.
# Saved at https://dune.com/queries/7582218
VITE_DUNE_VOLUME_QUERY_ID=7582218

# Phase 4: cross-DEX source-attribution query (aggregator / CoW solver).
# Saved at https://dune.com/queries/7582229
VITE_DUNE_SOURCE_QUERY_ID=7582229

# Phase 4b: Balancer-only source attribution.
# Saved at https://dune.com/queries/7587484
VITE_DUNE_BALANCER_SOURCE_QUERY_ID=7587484
